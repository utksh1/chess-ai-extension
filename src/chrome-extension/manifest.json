{
  "manifest_version": 3,
  "name": "Chess.com AI Player",
  "version": "1.0.0",
  "description": "AI agent that can play chess games on chess.com",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.chess.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.chess.com/*"],
      "js": ["lib/chess.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/stockfish.js", "lib/stockfish.wasm", "lib/stockfish.wasm.js"],
      "matches": ["https://www.chess.com/*"]
    }
  ]
}
